# Dashboard password (defaults to 'admin' if not set)
VITE_DASHBOARD_PASSWORD=admin

# Signaling server URL (leave empty for local dev, set for production)
VITE_SIGNALING_URL=

# ICE servers (optional, defaults to public STUN)
VITE_STUN_URL=stun:stun.l.google.com:19302

# TURN server (optional but recommended for NAT traversal)
# Get free TURN credentials from: https://www.metered.ca/tools/openrelay/
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_PASSWORD=

# Server port
PORT=3001
