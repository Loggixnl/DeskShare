# JWT secret for authentication (required - change in production!)
JWT_SECRET=change-this-to-a-secure-random-string

# Database path (defaults to ./data/deskshare.db)
DATABASE_PATH=./data/deskshare.db

# Signaling server URL (leave empty for local dev, set for production)
VITE_SIGNALING_URL=

# API URL for auth endpoints (leave empty for local dev)
VITE_API_URL=

# ICE servers (optional, defaults to public STUN)
VITE_STUN_URL=stun:stun.l.google.com:19302

# TURN server (optional, for NAT traversal)
TURN_URL=
TURN_USERNAME=
TURN_PASSWORD=

# Server port
PORT=3001

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
